{
	"name": "oliup/code-generator",
	"description": "Simple code generator for PHP.",
	"type": "library",
	"license": "MIT",
	"require": {
		"php": ">=8.1",
		"silassare/php-utils": "^2.0.0"
	},
	"require-dev": {
		"oliup/oliup-cs-php": "dev-main",
		"roave/security-advisories": "dev-latest",
		"phpunit/phpunit": "^9.5.9",
		"vimeo/psalm": "^6.0"
	},
	"repositories": {
		"oliup/oliup-cs-php": {
			"type": "vcs",
			"url": "https://github.com/oliup-io/oliup-cs-php"
		}
	},
	"archive": {
		"exclude": [
			"/tests"
		]
	},
	"autoload": {
		"psr-4": {
			"OLIUP\\CG\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"OLIUP\\CG\\Tests\\": "tests/"
		}
	},
	"authors": [
		{
			"name": "Emile Silas SARE",
			"homepage": "https://github.com/silassare"
		}
	],
	"prefer-stable": true,
	"minimum-stability": "dev",
	"extra": {
		"branch-alias": {
			"dev-main": "1.x-dev"
		}
	},
	"config": {
		"platform": {
			"php": "8.1.31"
		},
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
